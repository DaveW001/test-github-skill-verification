.osgrep
node_modules/

# python cache artifacts
**/__pycache__/
*.py[cod]

# local scratch files
/temp_*
/tmp_*
nul

# migration backups with credentials
.conductor/tracks/*/artifacts/opencode.json.backup-pre-migration
.conductor/tracks/20260425-tool-search-plugin/artifacts/opencode.jsonc.backup-pre-tool-search

# Large database backups - exceeds GitHub 100MB limit, never commit
opencode.db

# Environment files with secrets - never commit
.env

# ---- Files containing secrets - never commit ----
# Google OAuth client ID/secret (mystatus quota-check one-liner)
docs/reference/mystatus-quota-check.md
# Gemini API keys (multiple people's keys documented here)
docs/reference/gemini-proxy.md
docs/troubleshooting/active/gemini-proxy-down.md
# Config backups containing Slack tokens and other live credentials
**/opencode.jsonc.before-*
**/opencode.jsonc.backup-*
