import { PermissionV1 } from "@opencode-ai/core/v1/permission"
import type { Agent } from "./agent"

/**
 * Build the `permission` ruleset for a subagent's session when it's spawned
 * via the task tool. Combines:
 *
 * 1. The parent session's deny rules and external_directory rules.
 *    Parent agent restrictions only govern that agent; the subagent's own
 *    permissions determine its capabilities.
 * 2. Default `todowrite` and `task` denies if the subagent's own ruleset
 *    doesn't already permit them.
 */
export function deriveSubagentSessionPermission(input: {
  parentSessionPermission: PermissionV1.Ruleset
  subagent: Agent.Info
}): PermissionV1.Ruleset {
  const canTask = input.subagent.permission.some((rule) => rule.permission === "task")
  const canTodo = input.subagent.permission.some((rule) => rule.permission === "todowrite")
  return [
    ...input.parentSessionPermission.filter(
      (rule) => rule.permission === "external_directory" || rule.action === "deny",
    ),
    ...(canTodo ? [] : [{ permission: "todowrite" as const, pattern: "*" as const, action: "deny" as const }]),
    ...(canTask ? [] : [{ permission: "task" as const, pattern: "*" as const, action: "deny" as const }]),
  ]
}

/**
 * Build the final permission ruleset for a Task-tool child session by combining
 * the subagent-derived session permission with the Task tool's blanket deny
 * rules, then de-duplicating identical rules.
 *
 * This is the exact inline construction previously embedded in
 * `src/tool/task.ts`, extracted verbatim to make the production child-session
 * permission path unit-testable. Runtime behavior is preserved byte-for-byte,
 * INCLUDING the current bug where any tool listed in `primaryTools` (e.g.
 * `compress` when DCP registers it via `experimental.primary_tools`) is
 * blanket-denied for every Task child. That bug is intentionally retained
 * here and will be removed in a later behavior-changing pass (plan Task 2.1);
 * do not "fix" it in this non-behavioral refactor.
 *
 * Inputs:
 * - parentSessionPermission: the parent session's existing permission ruleset
 *   (typically `parent.permission ?? []`).
 * - subagent: the resolved subagent `Agent.Info`; its `.permission` drives the
 *   todowrite / taskPermissionId default-deny branches.
 * - primaryTools: the `experimental.primary_tools` list from config (optional).
 * - taskPermissionId: the permission id of the Task tool itself (normally
 *   "task"); injected so the helper is unit-testable without hardcoding.
 */
export function buildChildSessionPermission(input: {
  parentSessionPermission: PermissionV1.Ruleset
  subagent: Agent.Info
  primaryTools?: string[]
  taskPermissionId: string
}): PermissionV1.Ruleset {
  const childPermission = deriveSubagentSessionPermission({
    parentSessionPermission: input.parentSessionPermission,
    subagent: input.subagent,
  })
  const childToolDenies: PermissionV1.Ruleset = [
    ...(input.subagent.permission.some((rule) => rule.permission === "todowrite")
      ? []
      : [{ permission: "todowrite" as const, pattern: "*" as const, action: "deny" as const }]),
    ...(input.subagent.permission.some((rule) => rule.permission === input.taskPermissionId)
      ? []
      : [{ permission: input.taskPermissionId, pattern: "*" as const, action: "deny" as const }]),
    ...(input.primaryTools?.map((permission) => ({
      permission,
      pattern: "*" as const,
      action: "deny" as const,
    })) ?? []),
  ]
  return [
    ...childPermission,
    ...childToolDenies.filter(
      (deny) =>
        !childPermission.some(
          (rule) =>
            rule.permission === deny.permission &&
            rule.pattern === deny.pattern &&
            rule.action === deny.action,
        ),
    ),
  ]
}
