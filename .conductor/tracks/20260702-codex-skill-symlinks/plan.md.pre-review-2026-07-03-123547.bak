  $results = foreach ($c in $conversion) {
    $backupSkill = Test-Path -LiteralPath (Join-Path $c.BackupPath 'SKILL.md')
    $targetSkill = Test-Path -LiteralPath (Join-Path $c.CanonicalTarget 'SKILL.md')
    [pscustomobject]@{ Name = $c.Name; BackupHasSkillMd = $backupSkill; TargetHasSkillMd = $targetSkill; Status = $(if($backupSkill -and $targetSkill){'convertible'}else{'review-required'}) }
  }
