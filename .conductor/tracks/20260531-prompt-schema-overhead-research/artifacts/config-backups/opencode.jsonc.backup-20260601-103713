  "disabled_providers": ["google-vertex", "google-vertex-anthropic", "moonshot"],
  "default_agent": "01-Planner",
  "small_model": "zai-coding-plan/glm-5.1",
  "snapshot": true,
  "username": "davew",
  "mcp": {
    "playwright": { "type": "local", "command": ["npx", "@playwright/mcp@latest"], "enabled": false },
    "control-chrome": { "type": "local", "command": ["npx", "-y", "chrome-devtools-mcp@latest", "--no-usage-statistics"], "enabled": false },
