      "models": {
        "kimi-k2.5": { "reasoning": true, "temperature": false, "name": "Kimi K2.5", "interleaved": { "field": "reasoning_content" }, "id": "kimi-k2.5" },
        "moonshot-v1-128k": { "reasoning": false, "name": "Moonshot V1 128K", "id": "moonshot-v1-128k" },
        "moonshot-v1-8k": { "reasoning": false, "name": "Moonshot V1 8K", "id": "moonshot-v1-8k" },
        "moonshot-v1-32k": { "reasoning": false, "name": "Moonshot V1 32K", "id": "moonshot-v1-32k" },
        "kimi-k1.5": { "reasoning": false, "name": "Kimi K1.5", "id": "kimi-k1.5" }
