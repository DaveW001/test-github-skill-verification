    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "bash": "allow",
    "task": "allow",
    "skill": {
      "osgrep": "allow",
      "Retro": "allow",
      "retro": "allow",
      "Conductor": "allow",
      "conductor": "allow",
      "*": "allow"
    },
    "lsp": "allow",
    "webfetch": "allow",
    "google_search": "allow",
    "websearch": "allow"
