      "options": {
        "baseURL": "http://127.0.0.1:8000/v1beta",
        "apiKey": "proxy-will-replace-this"
      }
    },
    "openai": {
      "npm": "@ai-sdk/openai",
      "options": {
        "reasoningEffort": "medium",
